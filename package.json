{
  "name": "entrybase",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "build": "tsc -b config/tsconfig.json && vite build --config config/vite.config.ts",
    "format": "prettier --ignore-path .gitignore --cache --write \"**/*.{js,jsx,cjs,mjs,ts,tsx,cts,mts}\"",
    "format:check": "prettier --ignore-path .gitignore --check \"**/*.{js,jsx,cjs,mjs,ts,tsx,cts,mts}\"",
    "lint": "eslint .",
    "preview": "vite preview --config config/vite.config.ts",
    "database-server": "tsx ./database-server/server.ts"
  },
  "prettier": {
    "plugins": [
      "./config/prettier-plugin-single-line-imports.mjs"
    ],
    "singleLineImports": true,
    "overrides": [
      {
        "files": [
          "**/*.{js,jsx,cjs,mjs}"
        ],
        "options": {
          "parser": "imports-babel"
        }
      },
      {
        "files": [
          "**/*.{ts,tsx,cts,mts}"
        ],
        "options": {
          "parser": "imports-typescript"
        }
      }
    ]
  },
  "dependencies": {
    "json-server": "^0.17.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/json-server": "^0.14.8",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
